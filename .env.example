# --- Django -------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-value
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database -------------------------------------------------------------
DATABASE_URL=postgres://openoncall:openoncall@db:5432/openoncall

# --- Redis / Celery ---------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Twilio (bring-your-own-account -- never shared/proxied across teams) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Web Push (generate with e.g. `vapid --gen`, or `python -m pywebpush.vapid`) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=

# --- Slack ------------------------------------------------------------------
# Per-team Incoming Webhook URLs are configured in the admin/dashboard on the
# Team model, NOT here -- different self-hosted teams may use different
# Slack workspaces. This signing secret is instance-wide: it verifies inbound
# interactivity callbacks (the "Acknowledge" button in Slack messages) and
# comes from your Slack App's "Basic Information -> Signing Secret".
SLACK_SIGNING_SECRET=

# --- Frontend -----------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
# Base URL the backend uses to build links back to the SPA in outbound
# notifications (Slack messages, SMS, etc).
FRONTEND_BASE_URL=http://localhost:5173
